generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  DRIVER
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String?
  phone      String?
  role       Role     @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}
